#!/usr/bin/env bash
# Pulsar Launcher - Quick launch for WezTerm
set -euo pipefail

# Determine script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PULSAR_ROOT="${SCRIPT_DIR}"
export PULSAR_BIN_DIR="${PULSAR_ROOT}/bin"

# Check if wezterm is installed
if [[ -f "${PULSAR_BIN_DIR}/wezterm" ]]; then
    # Launch wezterm
    exec "${PULSAR_BIN_DIR}/wezterm"
else
    # wezterm not found, offer to install
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "⭐ Pulsar Package Manager"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "WezTerm is not installed."
    echo ""
    read -p "Would you like to install WezTerm now? [Y/n] " -n 1 -r
    echo ""

    if [[ $REPLY =~ ^[Yy]$ ]] || [[ -z $REPLY ]]; then
        # Source the activation script to get pulsar command
        source "${SCRIPT_DIR}/activate"

        echo ""
        echo "Installing WezTerm..."
        pulsar install wezterm

        if [[ $? -eq 0 ]]; then
            echo ""
            echo "✓ Installation complete!"
            echo "Launching WezTerm..."
            sleep 1
            exec "${PULSAR_BIN_DIR}/wezterm"
        else
            echo ""
            echo "✗ Installation failed."
            exit 1
        fi
    else
        echo ""
        echo "Installation cancelled."
        exit 0
    fi
fi